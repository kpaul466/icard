// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: employees
// Document ID: auto-generated
// Fields:
//   - name: string (required) - Full name
//   - designation: string (required) - Job title
//   - agencyName: string (required) - Contractor name
//   - employeeId: string (required) - Agency ID
//   - bloodGroup: string (optional) - Blood group
//   - contactNumber: string (optional) - Phone
//   - photoUrl: string (optional) - Photo URL
//   - validUntil: string (optional) - Validity date
//   - cccName: string (required) - CCC Name
//   - createdAt: timestamp (required) - Creation time
//   - createdBy: string (required) - User UID
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "kkeshob@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAuthorized() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) || isAdmin());
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'designation', 'agencyName', 'cccName']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.designation is string && data.designation.size() > 0 && data.designation.size() < 100 &&
             data.agencyName is string && data.agencyName.size() > 0 && data.agencyName.size() < 100 &&
             data.cccName is string && data.cccName.size() > 0 && data.cccName.size() < 200;
    }

    match /employees/{employeeId} {
      // Allow authorized users to read and write their own employee records
      allow read: if isAuthorized();
      allow create: if isAuthorized() && 
                    isValidEmployee(request.resource.data) && 
                    request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthorized() && 
                    (resource.data.createdBy == request.auth.uid || isAdmin()) && 
                    isValidEmployee(request.resource.data);
      allow delete: if isAuthorized() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['officePhone', 'officeEmail', 'issuingAuthority', 'emergencyTag', 'cccName']) &&
             data.officePhone is string &&
             data.officeEmail is string &&
             data.issuingAuthority is string &&
             data.emergencyTag is string &&
             data.cccName is string;
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
